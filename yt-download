    read -p "Choice [1-3]: " choice
}

download() {
    local url="$1"
    local format="$2"
    local ext="$3"
    
    echo -e "${BLUE}‚Üí Downloading...${NC}"
    
    yt-dlp \
        -f "$format" \
        --merge-output-format "$ext" \
        -o "$OUTPUT_DIR/%(title)s.%(ext)s" \
        --download-archive "$ARCHIVE" \
        --embed-thumbnail \
        --add-metadata \
        --progress \
        --no-warnings \
        "$url"
}

notify() {
    local title="$1"
    notify-send "Download Complete" "$title" -i video-x-generic 2>/dev/null || echo -e "${GREEN}‚úď Done: $title${NC}"
}

